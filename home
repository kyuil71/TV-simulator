        function startSequencer() {
            if (!musicState.isPlaying || !musicState.ctx) return;
            const ctx = musicState.ctx;
            const now = ctx.currentTime;
            const { baseFreq, scale, style, bpm } = musicState.currentChannel;
            const notes = SCALES[scale];
            const beatTime = bpm > 0 ? 60 / bpm : 1.5;

            // Advanced Sequencer Logic per Style
            if (style === 'synth_pop') {
                playInstrument(0, 'kick', 0.2, now, 0.4);
                playInstrument(0, 'kick', 0.2, now + beatTime, 0.4);
                playInstrument(0, 'kick', 0.2, now + beatTime*2, 0.4);
                playInstrument(0, 'kick', 0.2, now + beatTime*3, 0.4);
                
                for(let i=0; i<8; i++) playInstrument(0, 'hihat', 0.05, now + i*(beatTime/2), 0.1);
                
                playInstrument(baseFreq/2, 'bass', beatTime*4, now, 0.3);
                
                [0, 2, 4].forEach(i => {
                     const pitch = notes[i % notes.length];
                     const freq = baseFreq * Math.pow(2, pitch/12);
                     playInstrument(freq, 'pad', beatTime*4, now, 0.15);
                });
                 musicState.sequencer = setTimeout(startSequencer, beatTime * 4 * 1000);

            } else if (style === 'piano_ballad') {
                 [0, 2, 4, 7].forEach((n, i) => {
                     const pitch = notes[n % notes.length];
                     const freq = baseFreq * Math.pow(2, pitch/12);
                     // irregular timing
                     playInstrument(freq, 'piano', 2, now + i*0.1 + (Math.random()*0.05), 0.25);
                 });
                 playInstrument(baseFreq/2, 'bass', 3, now, 0.2);
                 musicState.sequencer = setTimeout(startSequencer, beatTime * 2 * 1000);

            } else if (style === 'guitar_picking') {
                 [0, 2, 1, 3, 1, 2].forEach((n, i) => {
                    const pitch = notes[n % notes.length];
                    const freq = baseFreq * Math.pow(2, pitch/12);
                    playInstrument(freq, 'guitar', 0.5, now + i*(beatTime/2), 0.2);
                 });
                 musicState.sequencer = setTimeout(startSequencer, beatTime * 3 * 1000);

            } else if (style === 'fantasy_chimes') {
                 if(Math.random() > 0.4) {
                     const pitch = notes[Math.floor(Math.random()*notes.length)];
                     const freq = baseFreq * 2 * Math.pow(2, pitch/12);
                     playInstrument(freq, 'bell', 4, now, 0.2);
                 }
                 playInstrument(baseFreq, 'pad', 5, now, 0.15);
                 musicState.sequencer = setTimeout(startSequencer, 2500);
            } else {
                // Deep Drone
                playInstrument(baseFreq/2, 'bass', 8, now, 0.5);
                playInstrument(baseFreq, 'pad', 8, now, 0.2);
                musicState.sequencer = setTimeout(startSequencer, 7000);
            }
        }

