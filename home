        // Input Handlers
        function volumeUp() {
            if (!state.isPowerOn) return; playClick(); resetMusicIdleTimer();
            if (state.isMusicMode) { musicState.volume = Math.min(100, musicState.volume+5); updateMusicVolume(musicState.volume); return; }
            state.currentVolume = Math.min(100, state.currentVolume+10);
            if(tvVideoPlayer) tvVideoPlayer.volume = state.currentVolume/100;
            updateTVDisplay(true, "vol");
        }
        function volumeDown() {
            if (!state.isPowerOn) return; playClick(); resetMusicIdleTimer();
            if (state.isMusicMode) { musicState.volume = Math.max(0, musicState.volume-5); updateMusicVolume(musicState.volume); return; }
            state.currentVolume = Math.max(0, state.currentVolume-10);
            if(tvVideoPlayer) tvVideoPlayer.volume = state.currentVolume/100;
            updateTVDisplay(true, "vol");
        }
        function toggleMute() {
            if (!state.isPowerOn) return; playClick(); resetMusicIdleTimer();
            if (state.isMusicMode) { 
                const newVol = musicState.volume > 0 ? 0 : 70; 
                musicState.volume = newVol; updateMusicVolume(newVol); 
                return; 
            }
            state.isMuted = !state.isMuted;
            if(tvVideoPlayer) tvVideoPlayer.muted = state.isMuted;
            updateTVDisplay(true, "vol");
        }
        function channelUp() {
            if (!state.isPowerOn) return; playClick(); resetMusicIdleTimer();
            if (state.isMusicMode) { 
                const idx = musicChannels.findIndex(c => c.id === musicState.currentChannel.id);
                switchMusicChannel(musicChannels[(idx - 1 + musicChannels.length) % musicChannels.length]); 
                return; 
            }
            if(state.currentChannel < 30) state.currentChannel++; else state.currentChannel = 1;
            updateVideoForChannel(); updateTVDisplay(true, "ch");
        }
        function channelDown() {
            if (!state.isPowerOn) return; playClick(); resetMusicIdleTimer();
            if (state.isMusicMode) { 
                const idx = musicChannels.findIndex(c => c.id === musicState.currentChannel.id);
                switchMusicChannel(musicChannels[(idx + 1) % musicChannels.length]); 
                return; 
            }
            if(state.currentChannel > 1) state.currentChannel--; else state.currentChannel = 30;
            updateVideoForChannel(); updateTVDisplay(true, "ch");
        }
        
        function masterDpadHandler(key) {
            playClick(); resetMusicIdleTimer();
            if (!state.isPowerOn) return;

            if (state.isMusicMode) {
                if (key === 'ok') toggleMusicPlay();
                else if (key === 'left') volumeDown();
                else if (key === 'right') volumeUp();
                else if (key === 'up') channelUp();
                else if (key === 'down') channelDown();
                return;
            }
            if (state.isHomeMode) {
                if (['left', 'right', 'up', 'down'].includes(key)) {
                    moveHomeFocus(key === 'left'?'l':(key==='right'?'r':(key==='up'?'u':'d')));
                }
                else if (key === 'ok') {
                    const item = state.iotItems[state.focusedIotIndex];
                    if(item) { item.on = !item.on; if(item.type==='audio') toggleIoTMusic(item.on); playConfirm(); updateTVDisplay(); }
                }
                return;
            }
            if (state.isGeminiTrayOpen) {
                if (key === 'left') { state.focusedRecommendationIndex = Math.max(0, (state.focusedRecommendationIndex||0)-1); updateTVDisplay(); }
                else if (key === 'right') { state.focusedRecommendationIndex = Math.min(state.recommendations.length-1, (state.focusedRecommendationIndex||0)+1); updateTVDisplay(); }
                else if (key === 'ok') {
                    const item = state.recommendations[state.focusedRecommendationIndex];
                    if(item) {
                        state.currentChannel = item.channel; updateVideoForChannel(); 
                        state.isGeminiTrayOpen = false; updateTVDisplay(true, "ch");
                    }
                }
            }
        }

        function moveHomeFocus(dir) {
            const homeNavMap = { 0: { r: 1, d: 5 }, 1: { l: 0, r: 3, d: 5 }, 2: { l: 3, d: 4 }, 3: { l: 1, r: 2, d: 7 }, 4: { l: 3, d: 7 }, 5: { u: 1, r: 6 }, 6: { u: 3, l: 5, r: 7 }, 7: { u: 3, l: 6, r: 4 } };
            const n = homeNavMap[state.focusedIotIndex] && homeNavMap[state.focusedIotIndex][dir];
            if (n !== undefined) { state.focusedIotIndex = n; updateTVDisplay(); }
        }
        
        function setupHoldableButton(button, actionFunction) {
            if(!button) return;
            const startHold = (e) => { e.preventDefault(); if (holdInterval) clearInterval(holdInterval); actionFunction(); holdInterval = setInterval(actionFunction, 150); };
            const endHold = () => { clearInterval(holdInterval); };
            button.addEventListener('mousedown', startHold); button.addEventListener('mouseup', endHold); button.addEventListener('mouseleave', endHold);
            button.addEventListener('touchstart', startHold, {passive:false}); button.addEventListener('touchend', endHold);
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === '0') { handleFullscreen(); return; }
            if (e.key === 'Escape') { if (document.fullscreenElement) document.exitFullscreen().catch(()=>{}); return; }
            
            switch(e.key) {
                case '7': simulateButtonPress(powerButton); togglePower(); break;
                case '8': simulateButtonPress(standbyButton); toggleStandby(); break;
                case '9': simulateButtonPress(chUpButton); channelUp(); break;
                case '6': simulateButtonPress(chDownButton); channelDown(); break;
                case '+': simulateButtonPress(volUpButton); volumeUp(); break;
                case '-': simulateButtonPress(volDownButton); volumeDown(); break;
                case '4': simulateButtonPress(muteButton); toggleMute(); break;
                case '5': simulateButtonPress(homeButton); toggleHomeMode(); break;
                case '1': simulateButtonPress(geminiButton); geminiButton.click(); break;
                case '2': simulateButtonPress(musicButton); toggleMusicMode(); break;
                case 'ArrowUp': simulateButtonPress(dPadUp); masterDpadHandler('up'); break;
                case 'ArrowDown': simulateButtonPress(dPadDown); masterDpadHandler('down'); break;
                case 'ArrowLeft': simulateButtonPress(dPadLeft); masterDpadHandler('left'); break;
                case 'ArrowRight': simulateButtonPress(dPadRight); masterDpadHandler('right'); break;
                case 'Enter': simulateButtonPress(dPadOk); masterDpadHandler('ok'); break;
            }
        });

        function simulateButtonPress(btn) {
            if(btn) {
                btn.classList.add('active-key');
                setTimeout(() => btn.classList.remove('active-key'), 150);
            }
        }

