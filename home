<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TV 리모콘 시뮬레이터 (v86 - Standby & IoT Fix)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tone/14.7.77/Tone.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            overflow-x: hidden;
            overflow-y: auto;
            background-color: #111;
            user-select: none;
            -webkit-user-select: none;
        }
        .remote-button:active {
            transform: scale(0.96);
            filter: brightness(0.9);
        }
        .remote-button.active-key, .d-pad-button.active-key {
            transform: scale(0.95);
            filter: brightness(1.2);
            border-color: #fff;
        }
        #tv-screen {
            background-color: #000;
            position: relative;
            overflow: hidden;
            width: 100%;
            aspect-ratio: 16 / 9;
        }
        #tv-video-player {
            object-fit: cover;
            transition: opacity 0.5s;
            width: 100%; height: 100%;
        }
        .osd-container {
            background-color: rgba(20, 20, 20, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
            color: white;
            border-radius: 9999px;
            padding: 0.75rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            transition: opacity 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            opacity: 0;
        }
        .d-pad-container {
            display: grid;
            grid-template-areas: "music up standby" "left ok right" ". down .";
            grid-template-columns: 1fr 1fr 1fr;
            grid-template-rows: auto auto auto;
            gap: 0.5rem;
            align-items: center;
            justify-items: center;
        }
        #btn-standby { grid-area: standby; }
        #btn-music { grid-area: music; } 
        #d-pad-up { grid-area: up; }
        #d-pad-left { grid-area: left; }
        #d-pad-ok { grid-area: ok; }
        #d-pad-right { grid-area: right; }
        #d-pad-down { grid-area: down; }
        .d-pad-button {
            background-color: #27272a;
            border: 1px solid #3f3f46;
            border-radius: 50%;
            width: 4rem; height: 4rem;
            display: flex; align-items: center; justify-content: center;
            color: #e4e4e7;
            transition: all 0.15s;
            cursor: pointer;
        }
        .d-pad-button:active { background-color: #3f3f46; transform: scale(0.92); }
        #d-pad-ok { background-color: #3f3f46; border-color: #52525b; font-weight: 600; }
        .loader {
            width: 1.25rem; height: 1.25rem;
            border: 2px solid #FFF; border-bottom-color: transparent;
            border-radius: 50%; display: inline-block;
            box-sizing: border-box; animation: rotation 1s linear infinite;
        }
        @keyframes rotation { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        #gemini-recommendation-tray .gemini-item {
            flex-shrink: 0; position: relative;
            width: calc(100% / 5.3 - 0.75rem); 
            height: 8rem;
            background-color: #1c1c1e; border-radius: 0.75rem; overflow: hidden;
            cursor: pointer; transition: transform 0.2s cubic-bezier(0.25, 0.8, 0.25, 1), border-color 0.2s, box-shadow 0.2s;
            border: 3px solid transparent; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            box-sizing: border-box;
        }
        #gemini-recommendation-tray .gemini-item.dpad-focused {
            transform: none;
            border-color: #ffffff;
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.7);
            z-index: 10;
        }
        #gemini-recommendation-tray .gemini-item video, #gemini-recommendation-tray .gemini-item img { width: 100%; height: 100%; object-fit: cover; }
        #gemini-recommendation-tray .gemini-item-info {
            position: absolute; bottom: 0; left: 0; width: 100%; padding: 0.75rem;
            background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
            display: flex; flex-direction: column; justify-content: flex-end;
        }
        #gemini-recommendation-tray .gemini-item-title { font-weight: 600; color: #fff; font-size: 0.85rem; line-height: 1.2; margin-bottom: 0.2rem; }
        #gemini-recommendation-tray .gemini-item-channel { color: #d1d5db; font-size: 0.75rem; font-weight: 500; opacity: 0.8; }
        #gemini-recommendation-tray .overflow-x-auto::-webkit-scrollbar { display: none; }
        #gemini-recommendation-tray .overflow-x-auto { 
            -ms-overflow-style: none; scrollbar-width: none; 
            mask-image: linear-gradient(to right, black 90%, transparent 100%);
            -webkit-mask-image: linear-gradient(to right, black 90%, transparent 100%);
            padding-right: 2rem;
        }
        #home-iot-overlay {
            background-color: rgba(30, 30, 35, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border-radius: 1.5rem;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            transition: opacity 0.3s; 
            pointer-events: auto;
        }
        .room-division {
            position: absolute; border: 1px solid rgba(255, 255, 255, 0.3);
            background-color: rgba(255, 255, 255, 0.03);
            display: flex; align-items: center; justify-content: center;
        }
        .room-label { font-size: 0.6rem; color: rgba(255,255,255,0.7); font-weight: 600; letter-spacing: 0.05em; }
        .iot-item {
            position: absolute; transform: translate(-50%, -50%); transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(0,0,0,0.3); z-index: 50;
            cursor: pointer; 
        }
        .iot-item.focused { 
            border: 3px solid #f97316;
            box-shadow: 0 0 15px rgba(249, 115, 22, 0.6); 
            transform: translate(-50%, -50%) scale(1.2); 
            z-index: 60; 
        }
        .iot-item.on {
            background: #fcd34d !important; color: #451a03 !important;
            box-shadow: 0 0 25px rgba(252, 211, 77, 0.6) !important; transform: translate(-50%, -50%) scale(1.15) !important; z-index: 70;
        }
        .light-bulb { width: 28px; height: 28px; border-radius: 50%; background: #3f3f46; color: #a1a1aa; }
        .vacuum-cleaner { width: 32px; height: 32px; border-radius: 50%; background: #3f3f46; color: #a1a1aa; }
        .audio-system { width: 32px; height: 32px; border-radius: 0.75rem; background: #3f3f46; color: #a1a1aa; }
        @keyframes vacuum-move {
            0% { left: 40%; bottom: 10%; } 25% { left: 55%; bottom: 40%; } 50% { left: 65%; bottom: 80%; } 75% { left: 45%; bottom: 50%; } 100% { left: 40%; bottom: 10%; }
        }
        .vacuum-cleaning { animation: vacuum-move 12s linear infinite; }
        .remote-btn-style {
            background-color: #27272a;
            border: 1px solid #3f3f46;
            color: #f4f4f5;
            border-radius: 0.75rem;
            font-weight: 600;
            transition: all 0.1s;
            cursor: pointer;
        }
        .remote-btn-style:active { background-color: #3f3f46; transform: scale(0.95); }
        #standby-overlay-content {
            transform: scale(0.4); 
            transform-origin: top right; 
            position: absolute;
            top: 4rem;   
            right: 4rem; 
        }
        #standby-overlay { 
            background-color: black; 
            transition: opacity 1s ease-in-out; 
            z-index: 30; 
            width: 100%;
            height: 100%;
        }
        .video-hidden { opacity: 0 !important; }
        .font-sf-display { font-family: -apple-system, BlinkMacSystemFont, sans-serif; font-weight: 200; letter-spacing: -0.02em; }
        #music-app-overlay {
            transition: opacity 0.4s cubic-bezier(0.25, 0.8, 0.25, 1), transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            opacity: 0;
            top: 50%;
            right: 3rem;
            left: auto;
            transform: translateY(-50%) scale(0.55); 
            transform-origin: right center; 
        }
        #music-app-overlay.active {
            opacity: 1;
            transform: translateY(-50%) scale(0.55);
        }
        #music-app-overlay.dimmed {
            opacity: 0.1; 
        }
        .custom-scrollbar::-webkit-scrollbar { width: 0px; }
        .music-channel-item.active {
            background-color: rgba(255, 255, 255, 0.15);
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        }
    </style>
</head>
