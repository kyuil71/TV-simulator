        async function togglePower() {
            try { await initAudio(); } catch(e){} playClick();
            state.isPowerOn = !state.isPowerOn;
            if (state.isPowerOn) {
                state.currentChannel = state.lastChannel; 
                state.currentVolume = state.lastVolume; 
                if(tvVideoPlayer) { 
                    tvVideoPlayer.muted = state.isMuted; 
                    tvVideoPlayer.volume = state.currentVolume/100; 
                    // Ensure video starts on power on
                    updateVideoForChannel();
                }
            } else {
                state.lastChannel = state.currentChannel; 
                state.lastVolume = state.currentVolume;
                state.isMusicMode = false; state.isStandbyMode = false; state.isHomeMode = false; state.isGeminiTrayOpen = false;
                if(clockInterval) clearInterval(clockInterval);
                stopMusicAppAudio();
                if(tvVideoPlayer) { tvVideoPlayer.pause(); tvVideoPlayer.src = ""; } // Clear src
            }
            updateTVDisplay(true);
        }

