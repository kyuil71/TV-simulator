        if(standbyButton) standbyButton.addEventListener('click', toggleStandby);
        if(homeButton) homeButton.addEventListener('click', toggleHomeMode);
        if(musicButton) musicButton.addEventListener('click', toggleMusicMode);
        if(geminiButton) geminiButton.addEventListener('click', async () => { 
            await initAudio(); playClick(); 
            if(state.isGeminiLoading) return;
            if(state.isHomeMode) toggleHomeMode(); 
            if(state.isStandbyMode) toggleStandby(); 
            if(state.isMusicMode) toggleMusicMode();
            if(state.isGeminiTrayOpen) { state.isGeminiTrayOpen = false; updateTVDisplay(); }
            else handleGeminiSuggest(); 
        });

        if(muteButton) muteButton.addEventListener('click', toggleMute);
        setupHoldableButton(volUpButton, volumeUp); setupHoldableButton(volDownButton, volumeDown);
        setupHoldableButton(chUpButton, channelUp); setupHoldableButton(chDownButton, channelDown);
        
        if(dPadOk) dPadOk.addEventListener('click', () => masterDpadHandler('ok'));
        if(dPadUp) dPadUp.addEventListener('click', () => masterDpadHandler('up'));
        if(dPadDown) dPadDown.addEventListener('click', () => masterDpadHandler('down'));
        if(dPadLeft) dPadLeft.addEventListener('click', () => masterDpadHandler('left'));
        if(dPadRight) dPadRight.addEventListener('click', () => masterDpadHandler('right'));

        updateTVDisplay();
    });
    </script>
</body>
</html>
